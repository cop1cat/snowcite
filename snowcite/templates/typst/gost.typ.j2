// Generated by snowcite. Self-contained ГОСТ-style template for literature
// reviews. Targets the formatting bits of ГОСТ 7.32 that matter for a paper
// (not a full НИР report): Times New Roman 14pt, 1.5 line spacing, margins
// 30/15/20/20mm, numbered headings, gost-r-705-2008-numeric bibliography.
//
// Deliberately does NOT depend on @preview/modern-g7-32 — that package
// targets research reports and requires ministry/organization/manager
// metadata snowcite doesn't collect. A self-contained template also avoids
// breakage when upstream packages shift API between Typst releases.

#set document(title: "{{ title }}", author: "{{ author }}")
#set page(
  paper: "a4",
  margin: (left: 30mm, right: 15mm, top: 20mm, bottom: 20mm),
  numbering: "1",
  number-align: center,
)
#set text(
  font: ("Times New Roman", "Liberation Serif", "DejaVu Serif"),
  size: 14pt,
  lang: "{{ lang }}",
)
#set par(justify: true, leading: 1em, first-line-indent: 1.25cm)

#set heading(numbering: "1.1.1")
#show heading.where(level: 1): set text(weight: "bold", size: 14pt)
#show heading.where(level: 1): set block(above: 1.5em, below: 1em)
#show heading.where(level: 2): set text(weight: "bold", size: 14pt)

#align(center)[
  #text(size: 16pt, weight: "bold")[{{ title }}] \
  #v(1em)
  #text(size: 14pt)[{{ author }}] \
  #text(size: 12pt)[#datetime.today().display()]
]

#v(2em)

{{ sections }}

#bibliography(
  "references.yml",
  title: "Список использованных источников",
  style: "gost-r-705-2008-numeric",
)
